@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://supply-chain.ontology/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc:Company a owl:Class .

sc:HighDependencyRisk a owl:Class .

sc:Risk a owl:Class .

sc:SupplyChainRelation a owl:Class .

sc:hasRatio a owl:DatatypeProperty ;
    rdfs:range xsd:float .

sc:hasRiskLevel a owl:DatatypeProperty .

sc:purchasesFrom a owl:ObjectProperty .

sc:suppliesTo a owl:ObjectProperty .

